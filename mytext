<div class="relative min-h-screen overflow-hidden bg-[#020617] text-white">

  <!-- BACKGROUND IMAGE -->
  <div class="absolute inset-0">

    <img
      src="https://images.unsplash.com/photo-1552664730-d307ca884978?q=80&w=2070&auto=format&fit=crop"
      alt="CRM Background"
      class="h-full w-full object-cover"
    />

    <!-- DARK OVERLAY -->
    <div class="absolute inset-0 bg-slate-950/75"></div>

    <!-- PREMIUM GRADIENT OVERLAY -->
    <div
      class="absolute inset-0 bg-gradient-to-br from-[#0f172a]/95 via-[#312e81]/70 to-[#164e63]/70"
    ></div>

  </div>

  <!-- GLOW EFFECTS -->
  <div class="absolute inset-0 overflow-hidden">

    <!-- TOP LEFT -->
    <div
      class="absolute -left-32 -top-32 h-96 w-96 rounded-full bg-fuchsia-500/25 blur-3xl"
    ></div>

    <!-- TOP RIGHT -->
    <div
      class="absolute right-0 top-0 h-[350px] w-[350px] rounded-full bg-cyan-500/20 blur-3xl"
    ></div>

    <!-- BOTTOM -->
    <div
      class="absolute bottom-0 left-1/2 h-[400px] w-[400px] -translate-x-1/2 rounded-full bg-violet-500/20 blur-3xl"
    ></div>

  </div>

  <!-- LOGIN CONTAINER -->
  <div class="relative z-10 flex min-h-screen items-center justify-center p-6">

    <!-- LOGIN CARD -->
    <div
      class="w-full max-w-md rounded-[36px] border border-white/10 bg-white/10 p-8 shadow-[0_20px_80px_rgba(0,0,0,0.45)] backdrop-blur-2xl lg:p-10"
    >

      <!-- LOGO -->
      <div class="mb-8 flex items-center justify-center gap-4">

        <div
          class="flex h-16 w-16 items-center justify-center rounded-3xl bg-gradient-to-br from-fuchsia-500 via-violet-500 to-cyan-500 text-3xl font-black shadow-lg shadow-violet-500/40"
        >
          X
        </div>

        <div>

          <h1 class="text-4xl font-extrabold tracking-wide">
            crmX
          </h1>

          <p class="text-sm text-slate-300">
            Smart CRM Platform
          </p>

        </div>

      </div>

      <!-- HEADER -->
      <div class="mb-10 text-center">

        <h2 class="text-4xl font-bold leading-tight">
          Welcome Back
        </h2>

        <p class="mt-3 text-slate-300">
          Sign in to manage customers, leads and analytics
        </p>

      </div>

      <!-- FORM -->
      <form
        class="space-y-6"
        [formGroup]="loginForm"
        (ngSubmit)="submit()"
      >

        <!-- EMAIL -->
        <div>

          <label class="mb-2 block text-sm font-medium text-slate-200">
            Email Address
          </label>

          <input
            type="email"
            placeholder="john@example.com"
            formControlName="email"
            class="w-full rounded-2xl border border-white/10 bg-slate-900/70 px-5 py-4 text-white outline-none transition-all duration-300 placeholder:text-slate-500 focus:border-fuchsia-500 focus:ring-4 focus:ring-fuchsia-500/20"
          />

          @if (loginForm.controls.email.touched &&
          loginForm.controls.email.invalid) {

            <p class="mt-2 text-sm text-rose-400">
              Valid email is required
            </p>

          }

        </div>

        <!-- PASSWORD -->
        <div>

          <label class="mb-2 block text-sm font-medium text-slate-200">
            Password
          </label>

          <div class="relative">

            <input
              [type]="hidePassword() ? 'password' : 'text'"
              placeholder="Enter password"
              formControlName="password"
              class="w-full rounded-2xl border border-white/10 bg-slate-900/70 px-5 py-4 pr-14 text-white outline-none transition-all duration-300 placeholder:text-slate-500 focus:border-fuchsia-500 focus:ring-4 focus:ring-fuchsia-500/20"
            />

            <button
              type="button"
              (click)="togglePassword()"
              class="absolute right-4 top-1/2 -translate-y-1/2 text-slate-400 hover:text-white"
            >
              {{ hidePassword() ? '👁️' : '🙈' }}
            </button>

          </div>

          @if (loginForm.controls.password.touched &&
          loginForm.controls.password.invalid) {

            <p class="mt-2 text-sm text-rose-400">
              Password is required
            </p>

          }

        </div>

        <!-- OPTIONS -->
        <div class="flex items-center justify-between text-sm">

          <label class="flex items-center gap-2 text-slate-300">

            <input
              type="checkbox"
              formControlName="remember"
              class="h-4 w-4 rounded border-slate-700 bg-slate-900"
            />

            Remember me

          </label>

          <a
            href="#"
            class="font-medium text-cyan-400 transition hover:text-cyan-300"
          >
            Forgot Password?
          </a>

        </div>

        <!-- BUTTON -->
        <button
          type="submit"
          [disabled]="loading()"
          class="flex w-full items-center justify-center rounded-2xl bg-gradient-to-r from-fuchsia-600 via-violet-600 to-cyan-500 px-6 py-4 text-lg font-semibold transition-all duration-300 hover:scale-[1.02] hover:shadow-2xl hover:shadow-violet-500/40 disabled:cursor-not-allowed disabled:opacity-70"
        >
          {{ loading() ? 'Signing In...' : 'Sign In' }}
        </button>

      </form>

      <!-- FOOTER -->
      <div class="mt-8 text-center text-sm text-slate-300">

        Don’t have an account?

        <span class="cursor-pointer font-semibold text-cyan-400 hover:text-cyan-300">
          Create account
        </span>

      </div>

    </div>

  </div>

</div>
