              Email Address
            </label>

            <input
              type="email"
              placeholder="john@example.com"
              formControlName="email"
              class="w-full rounded-2xl border border-white/10 bg-slate-900/70 px-5 py-4 text-white outline-none transition-all duration-300 placeholder:text-slate-500 focus:border-fuchsia-500 focus:ring-4 focus:ring-fuchsia-500/20"
            />

            @if (loginForm.controls['email'].touched &&
            loginForm.controls['email'].invalid) {

              <p class="mt-2 text-sm text-rose-400">
                Valid email is required
              </p>

            }

          </div>

          <!-- PASSWORD -->
          <div>

            <label class="mb-2 block text-sm font-medium text-slate-200">
              Password
            </label>

            <div class="relative">

              <input
                [type]="hidePassword() ? 'password' : 'text'"
                placeholder="Enter password"
                formControlName="password"
                class="w-full rounded-2xl border border-white/10 bg-slate-900/70 px-5 py-4 pr-14 text-white outline-none transition-all duration-300 placeholder:text-slate-500 focus:border-cyan-400 focus:ring-4 focus:ring-cyan-400/20"
              />

              <button
                type="button"
                (click)="togglePassword()"
                class="absolute right-4 top-1/2 -translate-y-1/2 text-slate-400 hover:text-white"
              >
                {{ hidePassword() ? '👁️' : '🙈' }}
              </button>

            </div>

            @if (loginForm.controls['password'].touched &&
            loginForm.controls['password'].invalid) {

              <p class="mt-2 text-sm text-rose-400">
                Password is required
              </p>

            }

          </div>

          <!-- OPTIONS -->
          <!-- <div class="flex items-center justify-between text-sm">

            <label class="flex items-center gap-2 text-slate-300">

              <input
                type="checkbox"
                formControlName="remember"
                class="h-4 w-4 rounded border-slate-700 bg-slate-900"
              />

              Remember me

            </label>

            <a
              href="#"
              class="font-medium text-cyan-400 transition hover:text-cyan-300"
            >
              Forgot Password?
            </a>

          </div> -->

          <!-- BUTTON -->
          <button
            type="submit"
            [disabled]="loading()"
            class="flex w-full items-center justify-center rounded-2xl bg-gradient-to-r from-pink-500 via-violet-600 to-cyan-500 px-6 py-4 text-lg font-bold transition-all duration-300 hover:scale-[1.02] hover:shadow-[0_10px_40px_rgba(168,85,247,0.45)] disabled:cursor-not-allowed disabled:opacity-70"
          >
            {{ loading() ? 'Signing In...' : 'Sign In' }}
          </button>

        </form>

        <!-- FOOTER -->
        <!-- <div class="mt-8 text-center text-sm text-slate-300">

          Don’t have an account?

          <span
            class="cursor-pointer font-semibold text-cyan-400 hover:text-cyan-300"
          >
            Create account
          </span>

        </div> -->

      </div>

    </div>

  </div>

</div>


